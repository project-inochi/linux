/dts-v1/;

#include <dt-bindings/leds/common.h>

#include "sg2044.dtsi"

/ {
	model = "Sophgo SG2044 EVB 1.0";
	compatible = "sophgo,sg2044-evb", "sophgo,sg2044";

	aliases {
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;
		serial3 = &uart3;
	};

	chosen {
		bootargs = "console=ttyS1,115200n8 earlycon ignore_loglevel initrd=0x8b000000,32M no5lvl";
		stdout-path = "serial1:115200n8";
	};
};

&osc {
	clock-frequency = <25000000>;
};

&clk {
	assigned-clocks = <&clk CLK_DIV_AP_CPU_NORMAL_FIXED>,
			  <&clk CLK_DIV_RP_SYS_FIXED>,
			  <&clk CLK_DIV_TPU_SYS_FIXED>,
			  <&clk CLK_DIV_CC_GRP_SYS_FIXED>,
			  <&clk CLK_DIV_SRC0_FIXED>,
			  <&clk CLK_DIV_SRC1_FIXED>,

			  <&clk CLK_MPLL2>,

			  <&clk CLK_DIV_AP_CPU_NORMAL_MAIN>,
			  <&clk CLK_DIV_TPU_SYS_MAIN>,
			  <&clk CLK_DIV_CC_GRP_SYS_MAIN>,
			  <&clk CLK_DIV_SRC0_MAIN>,
			  <&clk CLK_DIV_SRC1_MAIN>,

			  <&clk CLK_DIV_TOP_50M>,
			  <&clk CLK_DIV_TIMER1>,
			  <&clk CLK_DIV_TIMER2>,
			  <&clk CLK_DIV_TIMER3>,
			  <&clk CLK_DIV_TIMER4>,
			  <&clk CLK_DIV_TIMER5>,
			  <&clk CLK_DIV_TIMER6>,
			  <&clk CLK_DIV_TIMER7>,
			  <&clk CLK_DIV_TIMER8>,
			  <&clk CLK_DIV_PKA>,
			  <&clk CLK_DIV_UART_500M>,
			  <&clk CLK_DIV_EFUSE>,
			  <&clk CLK_DIV_TX_ETH0>,
			  <&clk CLK_DIV_PTP_REF_I_ETH0>,
			  <&clk CLK_DIV_REF_ETH0>,
			  <&clk CLK_DIV_EMMC>,
			  <&clk CLK_DIV_SD>,
			  <&clk CLK_DIV_TOP_AXI0>,
			  <&clk CLK_DIV_SD_100K>,
			  <&clk CLK_DIV_EMMC_100K>,
			  <&clk CLK_DIV_GPIO_DB>,
			  <&clk CLK_DIV_TOP_AXI_HSPERI>,
			  <&clk CLK_DIV_CXP_MAC_FIXED>,
			  <&clk CLK_DIV_PCIE_1G>;
	assigned-clock-rates = <2000000000>,
			       <2000000000>,
			       <1000000000>,
			       <2000000000>,
			       <1050000000>,
			       <900000000>,

			       <1000000000>,

			       <2000000000>,
			       <1000000000>,
			       <2000000000>,
			       <1050000000>,
			       <900000000>,

			       <50000000>,
			       <50000000>,
			       <50000000>,
			       <50000000>,
			       <50000000>,
			       <50000000>,
			       <50000000>,
			       <50000000>,
			       <50000000>,

			       <1000000000>,
			       <500000000>,
			       <25000000>,
			       <125000000>,
			       <50000000>,
			       <25000000>,
			       <400000000>,
			       <400000000>,
			       <100000000>,
			       <100000>,
			       <100000>,
			       <100000>,
			       <250000000>,
			       <1000000000>,
			       <1000000000>;
};

&emmc {
	bus-width = <4>;
	no-sdio;
	no-sd;
	non-removable;
	wp-inverted;
	status = "okay";
};

&gmac0 {
	phy-handle = <&phy0>;
	phy-mode = "rgmii-id";
	status = "okay";

	mdio {
		phy0: phy@0 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <0>;
		};
	};
};

&phy0 {
	reset-gpios = <&porta 28 GPIO_ACTIVE_LOW>;
	reset-assert-us = <10000>;
	reset-deassert-us = <10000>;
	rx-internal-delay-ps = <2050>;
};

&sd {
	bus-width = <4>;
	no-sdio;
	no-mmc;
	wp-inverted;
	status = "okay";
};

&uart1 {
	status = "okay";
};
